<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Shasha Gader — Artiste Plasticienne / Visual Artist</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Outfit:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    :root {
      --ink: #1a1410;
      --clay: #b5845a;
      --sand: #e8dcc8;
      --warm-white: #f5f0e8;
      --deep: #2c1f14;
      --accent: #c4703a;
      --text-light: #6b5c4e;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    html { scroll-behavior: smooth; }

    body {
      background: var(--warm-white);
      color: var(--ink);
      font-family: 'Outfit', sans-serif;
      font-weight: 300;
      overflow-x: hidden;
    }

    /* LANG TOGGLE */
    #lang-toggle {
      position: fixed;
      top: 1.2rem;
      right: 1.5rem;
      z-index: 100;
      display: flex;
      gap: 0.3rem;
      background: var(--warm-white);
      border: 1px solid var(--clay);
      border-radius: 2px;
      overflow: hidden;
    }

    #lang-toggle button {
      background: none;
      border: none;
      padding: 0.35rem 0.7rem;
      font-family: 'Outfit', sans-serif;
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      cursor: pointer;
      color: var(--text-light);
      transition: all 0.2s;
    }

    #lang-toggle button.active {
      background: var(--clay);
      color: white;
    }

    /* HERO */
    .hero {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 1fr 1fr;
      position: relative;
    }

    .hero-image {
      position: relative;
      overflow: hidden;
    }

    .hero-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: sepia(15%) contrast(1.05);
    }

    .hero-image::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to right, transparent 70%, var(--warm-white));
    }

    .hero-text {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 4rem 4rem 4rem 3rem;
      position: relative;
    }

    .hero-text::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: var(--clay);
    }

    .hero-eyebrow {
      font-size: 0.7rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--clay);
      margin-bottom: 1.5rem;
    }

    .hero-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(3.5rem, 6vw, 5.5rem);
      font-weight: 300;
      line-height: 0.95;
      color: var(--deep);
      margin-bottom: 1rem;
    }

    .hero-name em {
      font-style: italic;
      color: var(--clay);
    }

    .hero-subtitle {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem;
      font-style: italic;
      color: var(--text-light);
      margin-bottom: 2.5rem;
      line-height: 1.6;
    }

    .hero-divider {
      width: 3rem;
      height: 1px;
      background: var(--clay);
      margin-bottom: 2.5rem;
    }

    .hero-location {
      font-size: 0.75rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--text-light);
      margin-bottom: 3rem;
    }

    .hero-cta {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .btn-primary {
      display: inline-block;
      padding: 0.85rem 2rem;
      background: var(--clay);
      color: white;
      text-decoration: none;
      font-size: 0.75rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      transition: background 0.25s;
    }

    .btn-primary:hover { background: var(--deep); }

    .btn-secondary {
      display: inline-block;
      padding: 0.85rem 2rem;
      border: 1px solid var(--clay);
      color: var(--clay);
      text-decoration: none;
      font-size: 0.75rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      transition: all 0.25s;
    }

    .btn-secondary:hover {
      background: var(--clay);
      color: white;
    }

    /* NAV */
    nav {
      background: var(--deep);
      padding: 1rem 4rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: sticky;
      top: 0;
      z-index: 50;
    }

    .nav-logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.2rem;
      color: var(--sand);
      letter-spacing: 0.05em;
    }

    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }

    .nav-links a {
      color: var(--sand);
      text-decoration: none;
      font-size: 0.75rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      opacity: 0.8;
      transition: opacity 0.2s;
    }

    .nav-links a:hover { opacity: 1; }

    /* SECTIONS */
    section {
      padding: 6rem 4rem;
    }

    .section-label {
      font-size: 0.7rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--clay);
      margin-bottom: 1rem;
    }

    .section-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2rem, 4vw, 3.2rem);
      font-weight: 300;
      color: var(--deep);
      margin-bottom: 2rem;
      line-height: 1.1;
    }

    /* ABOUT */
    .about {
      background: var(--sand);
      display: grid;
      grid-template-columns: 1fr 1.6fr;
      gap: 5rem;
      align-items: start;
    }

    .about-left { padding-top: 0.5rem; }

    .about-portrait {
      width: 100%;
      aspect-ratio: 3/4;
      object-fit: cover;
      filter: sepia(10%) contrast(1.05);
    }

    .about-text {
      font-size: 1rem;
      line-height: 1.85;
      color: var(--ink);
      margin-bottom: 1.5rem;
    }

    .about-text strong {
      color: var(--clay);
      font-weight: 400;
    }

    /* GALLERY */
    .gallery { background: var(--warm-white); }

    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 2px;
      margin-top: 3rem;
    }

    .artwork-card {
      position: relative;
      overflow: hidden;
      background: var(--sand);
      cursor: pointer;
    }

    .artwork-card img {
      width: 100%;
      aspect-ratio: 4/3;
      object-fit: cover;
      display: block;
      transition: transform 0.5s ease, filter 0.5s ease;
      filter: sepia(5%);
    }

    .artwork-card:hover img {
      transform: scale(1.04);
      filter: sepia(0%);
    }

    .artwork-info {
      padding: 1.2rem 1.4rem;
      border-top: 1px solid rgba(0,0,0,0.08);
    }

    .artwork-number {
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      color: var(--clay);
      text-transform: uppercase;
      margin-bottom: 0.3rem;
    }

    .artwork-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.15rem;
      font-weight: 400;
      color: var(--deep);
      margin-bottom: 0.3rem;
    }

    .artwork-technique {
      font-size: 0.75rem;
      color: var(--text-light);
      margin-bottom: 0.5rem;
      line-height: 1.4;
    }

    .artwork-meta {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 0.8rem;
    }

    .artwork-year {
      font-size: 0.7rem;
      color: var(--text-light);
      letter-spacing: 0.1em;
    }

    .artwork-price {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem;
      color: var(--clay);
      font-weight: 600;
    }

    .artwork-dims {
      font-size: 0.68rem;
      color: var(--text-light);
      margin-top: 0.2rem;
    }

    /* CONTACT */
    .contact {
      background: var(--deep);
      color: var(--sand);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: start;
    }

    .contact .section-title { color: var(--sand); }
    .contact .section-label { color: var(--clay); }

    .contact-text {
      font-size: 0.95rem;
      line-height: 1.8;
      color: rgba(232,220,200,0.75);
      margin-bottom: 2rem;
    }

    .contact-item {
      display: flex;
      flex-direction: column;
      margin-bottom: 1.5rem;
    }

    .contact-item-label {
      font-size: 0.65rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--clay);
      margin-bottom: 0.3rem;
    }

    .contact-item-value {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem;
      color: var(--sand);
    }

    .contact-item-value a {
      color: var(--sand);
      text-decoration: none;
      border-bottom: 1px solid rgba(181,132,90,0.4);
      transition: border-color 0.2s;
    }

    .contact-item-value a:hover {
      border-color: var(--clay);
    }

    .instagram-link {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      margin-top: 2rem;
      padding: 0.8rem 1.5rem;
      border: 1px solid var(--clay);
      color: var(--sand);
      text-decoration: none;
      font-size: 0.75rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      transition: all 0.25s;
    }

    .instagram-link:hover {
      background: var(--clay);
    }

    /* MODAL */
    .modal-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(26,20,16,0.92);
      z-index: 200;
      justify-content: center;
      align-items: center;
      padding: 2rem;
    }

    .modal-overlay.open { display: flex; }

    .modal {
      background: var(--warm-white);
      max-width: 900px;
      width: 100%;
      display: grid;
      grid-template-columns: 1fr 1fr;
      max-height: 90vh;
      overflow: auto;
    }

    .modal img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .modal-details {
      padding: 2.5rem;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .modal-number {
      font-size: 0.65rem;
      letter-spacing: 0.25em;
      color: var(--clay);
      text-transform: uppercase;
      margin-bottom: 0.5rem;
    }

    .modal-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2rem;
      font-weight: 300;
      color: var(--deep);
      margin-bottom: 1rem;
      line-height: 1.1;
    }

    .modal-divider {
      width: 2rem;
      height: 1px;
      background: var(--clay);
      margin-bottom: 1.2rem;
    }

    .modal-technique {
      font-size: 0.85rem;
      color: var(--text-light);
      margin-bottom: 0.5rem;
      line-height: 1.5;
    }

    .modal-year-dims {
      font-size: 0.8rem;
      color: var(--text-light);
      margin-bottom: 2rem;
    }

    .modal-description {
      font-size: 0.9rem;
      line-height: 1.75;
      color: var(--ink);
      margin-bottom: 2rem;
      flex-grow: 1;
    }

    .modal-price {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.8rem;
      color: var(--clay);
      margin-bottom: 1.2rem;
    }

    .modal-enquire {
      display: block;
      text-align: center;
      padding: 0.9rem;
      background: var(--clay);
      color: white;
      text-decoration: none;
      font-size: 0.75rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      transition: background 0.2s;
    }

    .modal-enquire:hover { background: var(--deep); }

    .modal-close {
      position: absolute;
      top: 1rem;
      right: 1.5rem;
      font-size: 1.5rem;
      cursor: pointer;
      color: var(--sand);
      background: none;
      border: none;
      line-height: 1;
    }

    /* FOOTER */
    footer {
      background: var(--ink);
      color: rgba(232,220,200,0.5);
      text-align: center;
      padding: 2rem;
      font-size: 0.7rem;
      letter-spacing: 0.1em;
    }

    /* FADE IN */
    .fade-in {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }

    .fade-in.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* RESPONSIVE */
    @media (max-width: 900px) {
      .hero { grid-template-columns: 1fr; min-height: auto; }
      .hero-image { height: 60vw; }
      .hero-image::after { background: linear-gradient(to top, var(--warm-white) 10%, transparent); }
      .hero-text { padding: 2.5rem 2rem; }
      .about { grid-template-columns: 1fr; gap: 2rem; padding: 3rem 2rem; }
      .about-portrait { max-height: 50vw; width: 60%; }
      .contact { grid-template-columns: 1fr; gap: 2rem; padding: 3rem 2rem; }
      section { padding: 3rem 2rem; }
      nav { padding: 1rem 2rem; }
      .nav-links { gap: 1.5rem; }
      .modal { grid-template-columns: 1fr; }
      .modal img { max-height: 50vw; }
    }

    @media (max-width: 600px) {
      .gallery-grid { grid-template-columns: 1fr; }
      .nav-links li:nth-child(2) { display: none; }
    }
  </style>
</head>
