    }
  ];

  // ---- LANGUAGE ----
  let currentLang = 'fr';

  function setLang(lang) {
    currentLang = lang;
    document.querySelectorAll('[data-fr]').forEach(el => {
      el.innerHTML = el.getAttribute('data-' + lang);
    });
    document.querySelectorAll('#lang-toggle button').forEach((btn, i) => {
      btn.classList.toggle('active', (i === 0 && lang === 'fr') || (i === 1 && lang === 'en'));
    });
    renderGallery();
  }

  // ---- GALLERY ----
  function renderGallery() {
    const grid = document.getElementById('gallery-grid');
    grid.innerHTML = artworks.map(a => `
      <div class="artwork-card fade-in" onclick="openModal('${a.id}')">
        <img src="${a.img}" alt="${currentLang === 'fr' ? a.title_fr : a.title_en}"
          onerror="this.style.background='#c4a882';this.style.minHeight='220px';this.removeAttribute('src')">
        <div class="artwork-info">
          <p class="artwork-number">${a.id}</p>
          <p class="artwork-title">${currentLang === 'fr' ? a.title_fr : a.title_en}</p>
          <p class="artwork-technique">${a.technique}</p>
          <p class="artwork-dims">${a.dims}</p>
          <div class="artwork-meta">
            <span class="artwork-year">${a.year}</span>
            <span class="artwork-price">${a.price}</span>
          </div>
        </div>
      </div>
    `).join('');
    observeFadeIns();
  }

  // ---- MODAL ----
  function openModal(id) {
    const a = artworks.find(x => x.id === id);
    if (!a) return;
    document.getElementById('modal-img').src = a.img;
    document.getElementById('modal-number').textContent = a.id;
    document.getElementById('modal-title').textContent = currentLang === 'fr' ? a.title_fr : a.title_en;
    document.getElementById('modal-technique').textContent = a.technique;
    document.getElementById('modal-year-dims').textContent = `${a.year} · ${a.dims}`;
    document.getElementById('modal-description').textContent = currentLang === 'fr' ? a.desc_fr : a.desc_en;
    document.getElementById('modal-price').textContent = a.price;
    const phone = '22178993820';
    const msgFr = `Bonjour Shasha, je suis intéressé(e) par l'oeuvre "${a.title_fr}" (${a.id}) — ${a.price}. Pouvez-vous me donner plus d'informations ?`;
    const msgEn = `Hello Shasha, I am interested in the work "${a.title_en}" (${a.id}) — ${a.price}. Could you give me more information?`;
    const msg = encodeURIComponent(currentLang === 'fr' ? msgFr : msgEn);
    document.getElementById('modal-enquire').href = `https://wa.me/${phone}?text=${msg}`;
    document.getElementById('modal-enquire').textContent = currentLang === 'fr' ? "Demande via WhatsApp" : "Enquire via WhatsApp";
    document.getElementById('modal-overlay').classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeModal(e) {
    if (e.target === document.getElementById('modal-overlay')) closeModalDirect();
  }

  function closeModalDirect() {
    document.getElementById('modal-overlay').classList.remove('open');
    document.body.style.overflow = '';
  }

  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModalDirect(); });

  // ---- FADE IN ----
  function observeFadeIns() {
    const observer = new IntersectionObserver(entries => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } });
    }, { threshold: 0.1 });
    document.querySelectorAll('.fade-in:not(.visible)').forEach(el => observer.observe(el));
  }

  // ---- INIT ----
  renderGallery();
  observeFadeIns();
</script>
</body>
